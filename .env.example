# Database
DB_PASSWORD=your-strong-password

# Backend
SECRET_KEY=your-random-secret-key-at-least-32-characters-long

# CORS (comma-separated origins allowed to call the API)
CORS_ORIGINS=http://localhost,http://your-server-ip

# Nginx port (single entry point)
PORT=80

# Frontend API base (through nginx, same origin)
API_BASE_URL=http://your-server-ip/api
